---
import Layout from '../layouts/Layout.astro';
import { config } from '../config';
---
<Layout title={config.siteName}>
  <div class="page-frame home-page">
    <div class="card" style="text-align: center;">
      <h1 class="book-title">{config.siteName}</h1>
      <p class="cover-subtitle">{config.cover.subtitle}</p>
      <a href="/poems/" class="enter-link">{config.cover.cta}</a>
    </div>

    <p class="support-footnote">
      <i>"a robot playing with her robots"</i>; if you enjoy this artwork, consider <a href="https://donationvonsteinkirchcom.vercel.app/" target="_blank" rel="noopener noreferrer">supporting it</a> 
    </p>
  </div>
</Layout>
