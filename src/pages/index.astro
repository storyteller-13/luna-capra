---
import Layout from '../layouts/Layout.astro';
import { config } from '../config';
---
<Layout title={config.siteName}>
  <div class="page-frame home-page">
    <div class="card" style="text-align: center;">
      <h1 class="book-title">{config.siteName}</h1>
      <p class="cover-subtitle">{config.cover.subtitle}</p>
      <a href="/poems/" class="enter-link">{config.cover.cta}</a>
    </div>
    <footer class="support-footnote">
      <p>
        please consider supporting my work through a <a href="https://donationvonsteinkirchcom.vercel.app/" target="_blank" rel="noopener noreferrer">donation</a>, by <a href="https://github.com/sponsors/von-steinkirch" target="_blank" rel="noopener noreferrer">sponsoring me</a>, by using my <a href="https://sundaychats.vercel.app" target="_blank" rel="noopener noreferrer">services</a>, or by subscribing to my <a href="https://logic-13.vercel.app/" target="_blank" rel="noopener noreferrer">sci-fi storybook</a> or my <a href="https://future-ai-app.vercel.app/" target="_blank" rel="noopener noreferrer">prediciton app</a>.
      </p>
    </footer>
  </div>
</Layout>
